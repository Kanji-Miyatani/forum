# ============================================================
# Payload CMS シークレットキー（必須）
# 生成: openssl rand -base64 32
# ============================================================
PAYLOAD_SECRET=your-secret-key-change-this-in-production

# ============================================================
# データベース接続（PostgreSQL）
# ============================================================

# ローカル開発
DATABASE_URI=postgresql://postgres:password@localhost:5432/cms

# Railway 本番環境
# Railway で PostgreSQL アドオンを追加すると DATABASE_URL が自動設定されます
# 変数名を DATABASE_URI に変更するか、以下のように参照してください:
# DATABASE_URI=${{Postgres.DATABASE_URL}}

# ============================================================
# メディアアップロード先（本番: Railway Volume または S3）
# ============================================================
MEDIA_DIR=../public/media

# ============================================================
# Next.js 公開URL
# ============================================================

# ローカル開発
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Railway 本番（Railway が発行するドメイン）
# NEXT_PUBLIC_SERVER_URL=https://your-app.up.railway.app

# ============================================================
# Node.js 環境
# ============================================================
NODE_ENV=production
