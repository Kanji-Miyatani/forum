# ============================================================
# Payload CMS 設定
# ============================================================

# シークレットキー（必須・本番環境では強力なランダム文字列を設定）
# 生成例: openssl rand -base64 32
PAYLOAD_SECRET=your-secret-key-change-this-in-production

# ============================================================
# データベース設定
# ============================================================

# ローカル開発環境（SQLite）
DATABASE_URI=file:./forum.db

# Railway 本番環境（Volume を /data にマウントした場合）
# DATABASE_URI=file:/data/forum.db

# ============================================================
# アップロードメディア設定
# ============================================================

# ローカル開発環境
# MEDIA_DIR=../public/media

# Railway 本番環境（Volume を /data にマウントした場合）
# MEDIA_DIR=/data/media

# ============================================================
# Next.js 公開URL
# ============================================================

# ローカル開発
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Railway 本番環境（Railway が発行するドメインに合わせる）
# NEXT_PUBLIC_SERVER_URL=https://your-app.up.railway.app
