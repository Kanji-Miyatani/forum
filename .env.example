# Payload CMS のシークレットキー（本番環境では強力なランダム文字列を設定）
PAYLOAD_SECRET=your-secret-key-change-this-in-production

# データベースのURL（SQLite の場合はパスを指定）
DATABASE_URI=file:./forum.db

# Next.js のパブリックURL
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# スーパー管理者のメールアドレスとパスワード（初回起動時に自動作成）
PAYLOAD_SUPER_ADMIN_EMAIL=admin@example.com
PAYLOAD_SUPER_ADMIN_PASSWORD=adminpassword
